  "version": "0.22.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4205",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
	"test": "ng test --coverage",
	"test:watch": "ng test --watch",
