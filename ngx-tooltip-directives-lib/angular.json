{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-tooltip-directives": {
      "projectType": "library",
      "root": "projects/ngx-tooltip-directives",
      "sourceRoot": "projects/ngx-tooltip-directives/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ngx-tooltip-directives/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngx-tooltip-directives/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngx-tooltip-directives/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
		"test": {
			"builder": "@angular/build:unit-test",
			"options": {
				"tsConfig": "tsconfig.spec.json",
				"runnerConfig": "vitest.config.ts",
				"providersFile": "projects/ngx-tooltip-directives/src/test-providers.ts",
				"coverage": true,
				"coverageInclude": [
					"projects/ngx-tooltip-directives/src/**/*.ts"
				],
				"coverageExclude": [
					"projects/ngx-tooltip-directives/src/**/*.spec.ts",
					"projects/ngx-tooltip-directives/src/test-providers.ts",
					"projects/ngx-tooltip-directives/src/public-api.ts",
					"projects/ngx-tooltip-directives/src/lib/**/*.module.ts",
					"projects/ngx-tooltip-directives/src/lib/mocks/mock-ngx-tooltip-directives.module.ts"
				],
				"coverageReporters": [
					"html",
					"text",
					"text-summary",
					"lcov"
				]
			}
		}
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
